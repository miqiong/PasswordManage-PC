<Window x:Class="PasswordManage.PC.RecordEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑条目"
        Height="500" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="标题" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="TitleBox" Margin="0,2,0,10"/>

                <TextBlock Text="用户名" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="UserBox" Margin="0,2,0,10"/>

                <TextBlock Text="密码" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="PassBox" Margin="0,2,0,10"/>

                <TextBlock Text="网址" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="UrlBox" Margin="0,2,0,10"/>

                <TextBlock Text="备注" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="NoteBox" MinHeight="90" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#FFB91C1C" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Margin="0,0,8,0" Padding="20,8" Click="OnCancelClick"/>
                <Button Content="保存" Padding="20,8" Click="OnSaveClick"
                        Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
