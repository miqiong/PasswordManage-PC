<Window x:Class="PasswordManage.PC.RecordDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="条目详情"
        Height="420" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="DetailStatus" Grid.Row="0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="标题" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="TitleBox" IsReadOnly="True" Margin="0,2,0,10" TextWrapping="Wrap"/>
                <TextBlock Text="用户名" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="UserBox" IsReadOnly="True" Margin="0,2,0,10"/>
                <TextBlock Text="密码" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="PassBox" IsReadOnly="True" Margin="0,2,0,10"/>
                <TextBlock Text="网址" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="UrlBox" IsReadOnly="True" Margin="0,2,0,10" TextWrapping="Wrap"/>
                <TextBlock Text="备注" Foreground="{StaticResource MutedBrush}" FontSize="11"/>
                <TextBox x:Name="NoteBox" IsReadOnly="True" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="2" Content="关闭" Margin="0,12,0,0" Padding="20,8" HorizontalAlignment="Right" Click="OnCloseClick"/>
    </Grid>
</Window>
