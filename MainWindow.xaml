<Window x:Class="PasswordManage.PC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="密码库"
        Height="520" Width="400"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="24">
        <StackPanel x:Name="UnlockPanel" VerticalAlignment="Center">
            <TextBlock Text="个人密码库" FontSize="22" Foreground="{StaticResource FgBrush}" Margin="0,0,0,8"/>
            <TextBlock x:Name="HintText" Text="输入主密码以解锁" FontSize="13" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,20"/>
            <PasswordBox x:Name="MasterPasswordBox" Height="36" FontSize="14" Margin="0,0,0,12"/>
            <Button x:Name="PrimaryButton" Content="解锁" Height="40" FontSize="14" Click="OnPrimaryClick"
                    Background="{StaticResource AccentBrush}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <TextBlock x:Name="ErrorText" Foreground="#FFB91C1C" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
        </StackPanel>

        <Grid x:Name="ListPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <Button DockPanel.Dock="Right" Content="锁定" Padding="16,8" Click="OnLockClick"
                        Background="Transparent" BorderBrush="#FFE0E0E0" Cursor="Hand"/>
                <TextBlock Text="条目" FontSize="18" VerticalAlignment="Center" Foreground="{StaticResource FgBrush}"/>
            </DockPanel>
            <ListBox x:Name="RecordList" Grid.Row="1" BorderThickness="1" BorderBrush="#FFE8E8EA"
                     DisplayMemberPath="Summary"
                     MouseDoubleClick="OnRecordListDoubleClick"/>
            <TextBlock Grid.Row="2" x:Name="StatusText" Margin="0,12,0,0" FontSize="12"
                       Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</Window>
